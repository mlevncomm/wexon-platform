generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TableStatus {
  EMPTY
  OCCUPIED
  PAYMENT_PENDING
  PARTIALLY_PAID
  PAID
  RECEIPT_REQUESTED
  CLOSED
}

enum OrderStatus {
  NEW
  PREPARING
  SERVED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  FAILED
  REFUNDED
}

enum ReceiptStatus {
  REQUESTED
  PRINTED
  CANCELLED
}

enum NotificationType {
  ORDER_CREATED
  ORDER_UPDATED
  PAYMENT_RECEIVED
  RECEIPT_REQUESTED
  TABLE_UPDATED
  MENU_UPDATED
}

/// Menu modifier group selection mode (WexPay MenuProduct options).
enum MenuModifierSelectionType {
  SINGLE
  MULTI
}

enum MembershipRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  BILLING
  VIEWER
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

enum WexonProductStatus {
  ACTIVE
  UPCOMING
  INTERNAL
  DISABLED
}

enum BillingInterval {
  MONTHLY
  YEARLY
  ONE_TIME
}

enum EntitlementValueType {
  BOOLEAN
  INTEGER
  STRING
}

enum LicenseStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum LicenseType {
  MONTHLY
  YEARLY
  ONE_TIME
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
  OVERDUE
}

enum BillingPaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum SubscriptionPaymentStatus {
  INITIATED
  TOKEN_CREATED
  PENDING_CALLBACK
  PAID
  FAILED
  CANCELED
  EXPIRED
}

/// One-time Smart Activation fee per organization + product (Core billing).
enum ActivationFeeStatus {
  PENDING
  PAID
  WAIVED
  WAIVED_LEGACY
}

enum AppInstallationStatus {
  ACTIVE
  DISABLED
  PENDING
}

enum WexPayProviderCredentialMode {
  TEST
  LIVE
}

enum WexPayWebhookEventStatus {
  RECEIVED
  VERIFIED
  PROCESSED
  FAILED
  IGNORED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  legalName String?
  taxNo     String?
  email     String?
  phone     String?
  country   String   @default("TR")
  isDemo    Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships               Membership[]
  restaurants               Restaurant[]
  licenses                  License[]
  subscriptions             Subscription[]
  invoices                  Invoice[]
  billingPayments           BillingPayment[]
  subscriptionPayments      SubscriptionPayment[]
  activationFeeLedgers      ActivationFeeLedger[]
  appInstallations          AppInstallation[]
  auditLogs                 AuditLog[]
  apiKeys                   ApiKey[]
  webhookEndpoints          WebhookEndpoint[]
  wexPayProviderCredentials WexPayProviderCredential[]
  wexPayWebhookEvents       WexPayWebhookEvent[]

  @@index([isDemo])
  @@index([isActive])
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  phone              String?
  avatarUrl          String?
  isActive           Boolean   @default(true)
  passwordHash       String?
  passwordSetAt      DateTime?
  mustChangePassword Boolean   @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  memberships          Membership[]
  auditLogs            AuditLog[]
  apiKeys              ApiKey[]
  subscriptionPayments SubscriptionPayment[]

  @@index([isActive])
}

model Membership {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole   @default(STAFF)
  status         MembershipStatus @default(INVITED)
  invitedAt      DateTime         @default(now())
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([status])
}

model Product {
  id          String             @id @default(cuid())
  key         String             @unique
  name        String
  status      WexonProductStatus @default(UPCOMING)
  description String?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  plans                Plan[]
  licenses             License[]
  appInstallations     AppInstallation[]
  apiKeys              ApiKey[]
  webhookEndpoints     WebhookEndpoint[]
  activationFeeLedgers ActivationFeeLedger[]

  @@index([status])
  @@index([isActive])
}

model Plan {
  id                           String          @id @default(cuid())
  productId                    String
  key                          String          @unique
  name                         String
  description                  String?
  billingInterval              BillingInterval
  isPublic                     Boolean         @default(true)
  isActive                     Boolean         @default(true)
  sortOrder                    Int             @default(0)
  priceMonthly                 Decimal?        @db.Decimal(10, 2)
  priceYearly                  Decimal?        @db.Decimal(10, 2)
  priceOneTime                 Decimal?        @db.Decimal(10, 2)
  currency                     String          @default("TRY")
  taxRatePct                   Int             @default(20)
  /// Commercial tier key: essential | growth | scale | business_suite
  tierKey                      String?
  setupFee                     Decimal?        @db.Decimal(10, 2)
  /// Starting processing fee percent shown publicly (e.g. 2.89). Final rate underwriting-bound.
  processingFeePct             Decimal?        @db.Decimal(5, 2)
  /// Transaction-fee floor (₺). Invoice: planFee + max(actualTxnFees, this). Not an extra mystery fee.
  minimumTransactionCommitment Decimal?        @db.Decimal(10, 2)
  requiresManualReview         Boolean         @default(false)
  /// Non-guarantee settlement copy for public/admin display
  settlementDisplay            String?
  createdAt                    DateTime        @default(now())
  updatedAt                    DateTime        @updatedAt

  product              Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  entitlements         Entitlement[]
  licenses             License[]
  subscriptions        Subscription[]
  subscriptionPayments SubscriptionPayment[]

  @@index([productId])
  @@index([billingInterval])
  @@index([isActive])
  @@index([tierKey])
}

model Entitlement {
  id            String               @id @default(cuid())
  planId        String
  key           String
  valueType     EntitlementValueType
  valueBool     Boolean?
  valueInt      Int?
  valueString   String?
  isActive      Boolean              @default(true)
  deactivatedAt DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, key])
  @@index([planId])
  @@index([isActive])
}

model License {
  id             String        @id @default(cuid())
  organizationId String
  productId      String
  planId         String
  status         LicenseStatus @default(TRIAL)
  licenseType    LicenseType
  startsAt       DateTime      @default(now())
  endsAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product          Product           @relation(fields: [productId], references: [id])
  plan             Plan              @relation(fields: [planId], references: [id])
  subscription     Subscription?
  appInstallations AppInstallation[]

  @@index([organizationId])
  @@index([productId])
  @@index([planId])
  @@index([status])
}

model Subscription {
  id                 String             @id @default(cuid())
  organizationId     String
  licenseId          String             @unique
  planId             String
  status             SubscriptionStatus @default(TRIALING)
  interval           BillingInterval
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAt           DateTime?
  provider           String?
  providerRef        String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  license              License               @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  plan                 Plan                  @relation(fields: [planId], references: [id])
  invoices             Invoice[]
  billingPayments      BillingPayment[]
  subscriptionPayments SubscriptionPayment[]

  @@index([organizationId])
  @@index([planId])
  @@index([status])
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  subscriptionId String?
  invoiceNo      String        @unique
  status         InvoiceStatus @default(DRAFT)
  subtotal       Decimal       @db.Decimal(10, 2)
  tax            Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  currency       String        @default("TRY")
  issuedAt       DateTime?
  dueAt          DateTime?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription    Subscription?    @relation(fields: [subscriptionId], references: [id])
  billingPayments BillingPayment[]

  @@index([organizationId])
  @@index([subscriptionId])
  @@index([status])
}

model BillingPayment {
  id             String               @id @default(cuid())
  organizationId String
  subscriptionId String?
  invoiceId      String?
  amount         Decimal              @db.Decimal(10, 2)
  currency       String               @default("TRY")
  status         BillingPaymentStatus @default(PENDING)
  provider       String?
  providerRef    String?
  paidAt         DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id])

  @@index([organizationId])
  @@index([subscriptionId])
  @@index([invoiceId])
  @@index([status])
}

/// Platform PayTR iFrame ledger for Core subscription checkout (NOT WexPay operational Payment).
model SubscriptionPayment {
  id                        String                    @id @default(cuid())
  organizationId            String
  subscriptionId            String?
  planId                    String
  userId                    String?
  provider                  String                    @default("PAYTR")
  providerMode              String                    @default("iframe")
  merchantOid               String                    @unique
  amount                    Decimal                   @db.Decimal(10, 2)
  amountMinor               Int
  currency                  String                    @default("TRY")
  taxRatePct                Int                       @default(20)
  /// Immutable checkout quote snapshot (minor units). Additive — legacy rows may be null.
  subscriptionAmountMinor   Int?
  activationFeeAmountMinor  Int?
  netAmountMinor            Int?
  taxRateBps                Int?
  taxAmountMinor            Int?
  grossAmountMinor          Int?
  taxEnabledAtPurchase      Boolean?
  taxModeAtPurchase         String?
  billingInterval           BillingInterval
  status                    SubscriptionPaymentStatus @default(INITIATED)
  paytrTokenHash            String?
  callbackStatus            String?
  callbackTotalAmount       String?
  callbackPaymentAmount     String?
  callbackCurrency          String?
  failedReasonCode          String?
  failedReasonMsg           String?
  rawCallbackJson           Json?
  idempotencyKey            String?                   @unique
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  paidAt                    DateTime?

  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription         Subscription?        @relation(fields: [subscriptionId], references: [id])
  plan                 Plan                 @relation(fields: [planId], references: [id])
  user                 User?                @relation(fields: [userId], references: [id])
  activationFeeLedger  ActivationFeeLedger?

  @@index([organizationId])
  @@index([subscriptionId])
  @@index([planId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

/// One-time Smart Activation fee ledger — unique per organization + product.
model ActivationFeeLedger {
  id                    String              @id @default(cuid())
  organizationId        String
  productId             String
  planId                String?
  status                ActivationFeeStatus @default(PENDING)
  currency              String              @default("TRY")
  activationFeeMinor    Int                 @default(0)
  taxRateBps            Int                 @default(2000)
  taxEnabledAtPurchase  Boolean             @default(false)
  taxModeAtPurchase     String              @default("EXCLUSIVE")
  taxAmountMinor        Int                 @default(0)
  grossAmountMinor      Int                 @default(0)
  waivedReason          String?
  waivedByUserId        String?
  subscriptionPaymentId String?             @unique
  reservedUntil         DateTime?
  paidAt                DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product             Product              @relation(fields: [productId], references: [id])
  subscriptionPayment SubscriptionPayment? @relation(fields: [subscriptionPaymentId], references: [id])

  @@unique([organizationId, productId])
  @@index([status])
  @@index([productId])
}

model AppInstallation {
  id             String                @id @default(cuid())
  organizationId String
  productId      String
  licenseId      String?
  status         AppInstallationStatus @default(PENDING)
  settingsJson   Json?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])
  license      License?     @relation(fields: [licenseId], references: [id])

  @@unique([organizationId, productId])
  @@index([organizationId])
  @@index([productId])
  @@index([licenseId])
  @@index([status])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String?
  action         String
  entityType     String?
  entityId       String?
  level          String   @default("INFO")
  status         String   @default("SUCCESS")
  message        String?
  metadataJson   Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([level])
  @@index([status])
  @@index([createdAt])
}

model ApiKey {
  id             String    @id @default(cuid())
  organizationId String
  productId      String?
  userId         String?
  name           String
  prefix         String
  hashedKey      String
  scopes         String[]
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([productId])
  @@index([userId])
  @@index([prefix])
}

model WebhookEndpoint {
  id             String   @id @default(cuid())
  organizationId String
  productId      String?
  url            String
  secretHash     String
  events         String[]
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id])

  @@index([organizationId])
  @@index([productId])
  @@index([isActive])
}

model Restaurant {
  id             String   @id @default(cuid())
  organizationId String?
  name           String
  slug           String   @unique
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  branches     Branch[]

  @@index([organizationId])
}

model Branch {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  slug         String
  address      String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant     Restaurant             @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tables         RestaurantTable[]
  categories     MenuCategory[]
  products       MenuProduct[]
  modifierGroups MenuModifierGroup[]
  orders         CustomerOrder[]
  payments       Payment[]
  notifications  BusinessNotification[]

  @@unique([restaurantId, slug])
  @@index([restaurantId])
}

model RestaurantTable {
  id           String      @id @default(cuid())
  branchId     String
  label        String
  seats        Int         @default(4)
  qrCode       String      @unique
  status       TableStatus @default(EMPTY)
  isActive     Boolean     @default(true)
  lastClosedAt DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  branch          Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  orders          CustomerOrder[]
  payments        Payment[]
  receiptRequests ReceiptRequest[]

  @@unique([branchId, label])
  @@index([branchId])
}

model MenuCategory {
  id        String   @id @default(cuid())
  branchId  String
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch   Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  products MenuProduct[]

  @@unique([branchId, name])
  @@index([branchId])
}

model MenuProduct {
  id          String   @id @default(cuid())
  branchId    String
  categoryId  String
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("TRY")
  imageUrl    String?
  isActive    Boolean  @default(true)
  inStock     Boolean  @default(true)
  isPopular   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch                Branch                     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category              MenuCategory               @relation(fields: [categoryId], references: [id])
  orderItems            OrderItem[]
  productModifierGroups MenuProductModifierGroup[]

  /// Composite uniqueness enables tenant-safe join FKs (product + branch).
  @@unique([id, branchId])
  @@index([branchId])
  @@index([categoryId])
}

/// Branch-scoped modifier group (size, extras, removals). Shareable across products in the same branch.
/// Requiredness is derived: minSelect > 0. SINGLE groups must keep maxSelect = 1 (DB CHECK).
model MenuModifierGroup {
  id            String                    @id @default(cuid())
  branchId      String
  name          String
  selectionType MenuModifierSelectionType @default(SINGLE)
  minSelect     Int                       @default(0)
  maxSelect     Int                       @default(1)
  sortOrder     Int                       @default(0)
  isActive      Boolean                   @default(true)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  branch             Branch                     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  options            MenuModifierOption[]
  productLinks       MenuProductModifierGroup[]
  orderItemModifiers OrderItemModifier[]

  @@unique([branchId, name])
  /// Composite uniqueness enables tenant-safe join FKs (group + branch).
  @@unique([id, branchId])
  @@index([branchId])
  @@index([isActive])
}

model MenuModifierOption {
  id         String   @id @default(cuid())
  groupId    String
  name       String
  priceDelta Decimal  @default(0) @db.Decimal(10, 2)
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  group              MenuModifierGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  orderItemModifiers OrderItemModifier[]

  @@unique([groupId, name])
  @@index([groupId])
  @@index([isActive])
}

/// Same-branch M:N: composite FKs force product.branchId == group.branchId == branchId.
model MenuProductModifierGroup {
  id        String   @id @default(cuid())
  branchId  String
  productId String
  groupId   String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product MenuProduct       @relation(fields: [productId, branchId], references: [id, branchId], onDelete: Cascade)
  group   MenuModifierGroup @relation(fields: [groupId, branchId], references: [id, branchId], onDelete: Cascade)

  @@unique([productId, groupId])
  @@index([branchId])
  @@index([productId])
  @@index([groupId])
  @@index([isActive])
}

model CustomerOrder {
  id               String      @id @default(cuid())
  orderNo          String      @unique
  branchId         String
  tableId          String
  status           OrderStatus @default(NEW)
  note             String?
  receiptRequested Boolean     @default(false)
  subtotal         Decimal     @db.Decimal(10, 2)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  servedAt         DateTime?
  cancelledAt      DateTime?

  branch          Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  table           RestaurantTable        @relation(fields: [tableId], references: [id])
  items           OrderItem[]
  payments        Payment[]
  receiptRequests ReceiptRequest[]
  notifications   BusinessNotification[]

  @@index([branchId])
  @@index([tableId])
  @@index([status])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  totalPrice  Decimal @db.Decimal(10, 2)
  note        String?

  order     CustomerOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   MenuProduct         @relation(fields: [productId], references: [id])
  modifiers OrderItemModifier[]

  @@index([orderId])
  @@index([productId])
}

/// Immutable line-item modifier snapshot (names + delta). Soft FKs survive catalog edits/deletes.
model OrderItemModifier {
  id          String  @id @default(cuid())
  orderItemId String
  groupId     String?
  optionId    String?
  groupName   String
  optionName  String
  priceDelta  Decimal @db.Decimal(10, 2)
  sortOrder   Int     @default(0)

  orderItem OrderItem           @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  group     MenuModifierGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  option    MenuModifierOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@index([orderItemId])
  @@index([groupId])
  @@index([optionId])
}

model Payment {
  id               String        @id @default(cuid())
  branchId         String
  tableId          String
  orderId          String?
  amount           Decimal       @db.Decimal(10, 2)
  tipAmount        Decimal       @default(0) @db.Decimal(10, 2)
  currency         String        @default("TRY")
  status           PaymentStatus @default(PENDING)
  provider         String?
  providerRef      String?
  maskedCard       String?
  receiptRequested Boolean       @default(false)
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  branch          Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  table           RestaurantTable        @relation(fields: [tableId], references: [id])
  order           CustomerOrder?         @relation(fields: [orderId], references: [id])
  receiptRequests ReceiptRequest[]
  notifications   BusinessNotification[]

  @@index([branchId])
  @@index([tableId])
  @@index([orderId])
  @@index([status])
}

model ReceiptRequest {
  id        String        @id @default(cuid())
  tableId   String
  orderId   String?
  paymentId String?
  status    ReceiptStatus @default(REQUESTED)
  note      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  printedAt DateTime?

  table   RestaurantTable @relation(fields: [tableId], references: [id])
  order   CustomerOrder?  @relation(fields: [orderId], references: [id])
  payment Payment?        @relation(fields: [paymentId], references: [id])

  @@index([tableId])
  @@index([orderId])
  @@index([paymentId])
  @@index([status])
}

model BusinessNotification {
  id        String           @id @default(cuid())
  branchId  String
  orderId   String?
  paymentId String?
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  branch  Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  order   CustomerOrder? @relation(fields: [orderId], references: [id])
  payment Payment?       @relation(fields: [paymentId], references: [id])

  @@index([branchId])
  @@index([orderId])
  @@index([paymentId])
  @@index([isRead])
}

/// Tenant-scoped PSP credentials for operational WexPay payments (NOT Core BillingPayment).
model WexPayProviderCredential {
  id               String                       @id @default(cuid())
  organizationId   String
  provider         String
  displayName      String
  mode             WexPayProviderCredentialMode @default(TEST)
  isActive         Boolean                      @default(true)
  configCiphertext String
  keyFingerprint   String
  maskedKey        String
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider, mode])
  @@index([organizationId])
  @@index([provider])
  @@index([isActive])
}

/// Inbound PSP webhook events for WexPay operational payments. Separate from Core `WebhookEndpoint`.
model WexPayWebhookEvent {
  id              String                   @id @default(cuid())
  organizationId  String?
  provider        String
  providerEventId String
  eventType       String
  payloadHash     String
  rawBodyHash     String
  status          WexPayWebhookEventStatus @default(RECEIVED)
  errorMessage    String?
  receivedAt      DateTime                 @default(now())
  processedAt     DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([provider, providerEventId])
  @@index([organizationId])
  @@index([provider])
  @@index([status])
  @@index([receivedAt])
}

/// Postgres-backed idempotency for public QR mutations (survives serverless multi-instance).
model PublicIdempotencyRecord {
  id        String   @id @default(cuid())
  scopeKey  String   @unique
  status    Int
  bodyJson  Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}
