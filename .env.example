# Database — Supabase (recommended)
# Supabase Dashboard → Project Settings → Database → Connect
#
# Runtime (transaction pooler, port 6543):
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# Migrate / seed / preflight (direct session, port 5432):
# DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres
#
# Local-only Postgres (optional — not used if you already have Supabase on Vercel):
# DATABASE_URL=postgresql://user:password@localhost:5432/wexon
# DIRECT_URL=postgresql://user:password@localhost:5432/wexon
DATABASE_URL=
DIRECT_URL=

# Admin panel (required for smoke admin tests)
ADMIN_EMAILS=admin@example.com
ADMIN_LOGIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=32-byte-or-longer-random-secret-here

# Customer dashboard
CUSTOMER_SESSION_SECRET=32-byte-or-longer-random-secret-here
# Local dev only — leave unset in production (dev login fallback)
# CUSTOMER_DEV_LOGIN_PASSWORD=

# API keys
API_KEY_HASH_SECRET=32-byte-or-longer-random-secret-here

# WexPay sanal POS credential encryption (32-byte hex or base64)
WEXPAY_CREDENTIAL_ENCRYPTION_KEY=

# Canonical app URL for WexPay QR/payment callbacks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Maintenance / pre-application mode
# Production live service: false. Pre-application-only mode: true.
MAINTENANCE_MODE=false

# Public marketing site origin (production canonical: https://www.wexon.dev)
# NEXT_PUBLIC_WEXON_PUBLIC_ORIGIN=https://www.wexon.dev

# PayTR live API (operator/public checkout). Keep false for first production launch.
WEXPAY_PAYTR_ENABLE_API=false

# Smoke / Playwright
SMOKE_PORT=3100
SMOKE_BASE_URL=http://localhost:3100
# Must match prisma seed password for fixture user (real@wexon.dev). Placeholder "change-me" is ignored by E2E helpers.
SMOKE_CUSTOMER_PASSWORD=Wexon-Customer-2026
# SMOKE_SKIP_WEB_SERVER=1
# SMOKE_REUSE_SERVER=1

# Full-system E2E (optional aliases; never commit real secrets)
# Default target is local/preview. Production requires BOTH flags below.
# WEXON_E2E_TARGET=local
# WEXON_E2E_CONFIRM_PRODUCTION=false
# E2E_BASE_URL=http://localhost:3100
# E2E_PUBLIC_ORIGIN=http://localhost:3100
# E2E_CORE_ORIGIN=http://localhost:3100
# E2E_APP_ORIGIN=http://localhost:3100
# E2E_ADMIN_ORIGIN=http://localhost:3100
# E2E_CUSTOMER_EMAIL=
# E2E_CUSTOMER_PASSWORD=
# E2E_ADMIN_EMAIL=
# E2E_ADMIN_PASSWORD=
# Local Playwright webServer sets WEXON_E2E_RELAX_RATE_LIMIT=true automatically (never enable on real production).
