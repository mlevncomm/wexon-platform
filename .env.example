# Database — Supabase (recommended)
# Supabase Dashboard → Project Settings → Database → Connect
#
# Runtime (transaction pooler, port 6543):
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# Migrate / seed / preflight (direct session, port 5432):
# DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres
#
# Optional least-privilege runtime role (after LOGIN enabled in Dashboard; keep DIRECT_URL as postgres):
# DATABASE_URL=postgresql://wexon_app.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# Logical backup (Free plan): npm run db:backup  →  PG17+ custom archive in .backups/ (gitignored)
# Then: WEXON_ALLOW_LOCAL_DB_TESTS=1 npm run db:backup:test-restore -- .backups/<file>.dump
# JSONL debug export only (NOT A DISASTER-RECOVERY BACKUP): npm run db:export:jsonl
#
# Local-only Postgres (optional — not used if you already have Supabase on Vercel):
# DATABASE_URL=postgresql://user:password@localhost:5432/wexon
# DIRECT_URL=postgresql://user:password@localhost:5432/wexon
#
# Isolated WexPay E2E Postgres (docker-compose.e2e.yml — NEVER use against shared Supabase):
#   npm run e2e:db:up && npm run e2e:db:prepare
# DATABASE_URL=postgresql://wexon_e2e:wexon_e2e_dev_only@127.0.0.1:5433/wexon_e2e
# DIRECT_URL=postgresql://wexon_e2e:wexon_e2e_dev_only@127.0.0.1:5433/wexon_e2e
DATABASE_URL=
DIRECT_URL=

# Admin panel
# PR2B authorization uses Cloudflare Access JWT + PlatformAdmin (not shared password).
ADMIN_SESSION_SECRET=32-byte-or-longer-random-secret-here
CLOUDFLARE_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com
CLOUDFLARE_ACCESS_AUD=your-admin-application-audience

# Rollback-only (keep set on Vercel for emergency rollback — NOT used for authorization after PR2B):
ADMIN_EMAILS=admin@example.com
ADMIN_LOGIN_PASSWORD=change-me

# Local/CI Cloudflare Access test provider (NEVER set on Vercel production):
# WEXON_CF_ACCESS_TEST_MODE=1
# WEXON_CF_ACCESS_TEST_PRIVATE_JWK=
# WEXON_CF_ACCESS_TEST_PUBLIC_JWKS=

# Customer dashboard
CUSTOMER_SESSION_SECRET=32-byte-or-longer-random-secret-here
# LOCAL/TEST ONLY — must be UNSET in production (check-production-env fails if set).
# Used only when NODE_ENV is not production and WEXON_E2E_TARGET is local/test.
# CUSTOMER_DEV_LOGIN_PASSWORD=

# Transactional email (StaffInvite / Akıllı Aktivasyon)
# Production: WEXON_EMAIL_PROVIDER=resend + RESEND_API_KEY required (fail-closed).
# Local/test/preview: omit or set WEXON_EMAIL_PROVIDER=fake (no real sends).
# WEXON_EMAIL_PROVIDER=resend
# RESEND_API_KEY=
# WEXON_EMAIL_FROM=Wexon <davet@mail.wexon.dev>
# WEXON_EMAIL_REPLY_TO=

# API keys
API_KEY_HASH_SECRET=32-byte-or-longer-random-secret-here

# WexPay sanal POS credential encryption (32-byte hex or base64)
WEXPAY_CREDENTIAL_ENCRYPTION_KEY=

# Canonical app URL for WexPay QR/payment callbacks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Maintenance / pre-application mode
# Production live service: false. Pre-application-only mode: true.
MAINTENANCE_MODE=false

# Public marketing site origin (production canonical: https://www.wexon.dev)
# NEXT_PUBLIC_WEXON_PUBLIC_ORIGIN=https://www.wexon.dev

# PayTR live API (operator/public checkout). Keep false for first production launch.
# Live charge requires this flag + encrypted tenant merchant credentials.
WEXPAY_PAYTR_ENABLE_API=false

# Core subscription PayTR (platform merchant — NOT WexPay tenant credentials)
# Self-serve /checkout requires BOTH enable flags true + merchant credentials.
# Start with PAYTR_TEST_MODE=true. Callback URL: https://www.wexon.dev/api/billing/paytr/callback
# Keep recurring false until PayTR stored-card permissions are confirmed.
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=true
PAYTR_DEBUG_ON=false
PAYTR_IFRAME_ENABLE_API=false
PAYTR_SUBSCRIPTION_ENABLE_API=false
PAYTR_RECURRING_ENABLE_API=false
# Optional extra guard header; does NOT replace PayTR hash verification.
# PAYTR_CALLBACK_SECRET=

# Smoke / Playwright — local fixture password only (never use against production without explicit E2E password env)
SMOKE_PORT=3100
SMOKE_BASE_URL=http://localhost:3100
# Must match prisma seed password for local fixture user (real@wexon.dev). Placeholder "change-me" is ignored by E2E helpers.
SMOKE_CUSTOMER_PASSWORD=Wexon-Customer-2026
# SMOKE_SKIP_WEB_SERVER=1
# SMOKE_REUSE_SERVER=1

# Full-system E2E (optional aliases; never commit real secrets)
# Default target is local/preview. Production requires BOTH flags below.
# WEXON_E2E_TARGET=local
# WEXON_E2E_CONFIRM_PRODUCTION=false
#
# Isolated mutation E2E (local docker Postgres only — TARGET alone is not enough):
# WEXON_E2E_TARGET=isolated
# WEXON_E2E_CONFIRM_ISOLATED=true
# E2E_BASE_URL=http://localhost:3100
# E2E_PUBLIC_ORIGIN=http://localhost:3100
# E2E_CORE_ORIGIN=http://localhost:3100
# E2E_APP_ORIGIN=http://localhost:3100
# E2E_ADMIN_ORIGIN=http://localhost:3100
# E2E_CUSTOMER_EMAIL=
# E2E_CUSTOMER_PASSWORD=
# E2E_ADMIN_EMAIL=
# E2E_ADMIN_PASSWORD=
# Local Playwright webServer sets WEXON_E2E_RELAX_RATE_LIMIT=true automatically.
# MUST be unset in production — production:check fails if set; runtime also ignores it when NODE_ENV/VERCEL_ENV=production.
