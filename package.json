{
  "name": "wexon-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "playwright:install": "playwright install chromium",
    "test:smoke": "playwright test",
    "test:smoke:build": "npm run build && playwright test",
    "test:smoke:ci": "npm run build && playwright test",
    "test:e2e": "playwright test",
    "test:e2e:public": "playwright test e2e/public.spec.ts",
    "test:e2e:auth": "playwright test e2e/auth.spec.ts",
    "test:e2e:admin": "playwright test e2e/admin.spec.ts",
    "test:e2e:security": "playwright test e2e/security.spec.ts",
    "test:e2e:qr": "playwright test e2e/qr-customer-order.spec.ts e2e/public-checkout.spec.ts e2e/qr-order-api.spec.ts",
    "test:api": "playwright test e2e/qr-order-api.spec.ts e2e/public-checkout.spec.ts",
    "test:unit": "tsx --import ./scripts/load-local-env.mjs --test lib/wexpay-public-checkout.test.ts lib/wexpay-paytr-adapter.test.ts lib/wexpay-paytr-webhook-lookup.test.ts lib/wexpay-paytr-webhook.test.ts lib/wexon-rate-limit.test.ts lib/wexon-core-access.test.ts lib/wexon-canonical-host.test.ts lib/wexon/urls.test.ts lib/qr-order/pricing.test.ts lib/wexon-production-guards.test.ts lib/wexpay-validation.test.ts lib/wexpay-public-idempotency.test.ts scripts/cloudflare/admin-access-lib.test.ts",
    "production:check": "node scripts/check-production-env.mjs",
    "audit:demo-accounts": "node scripts/audit-demo-accounts.mjs",
    "production:check:psp": "node scripts/check-production-env.mjs --strict-psp",
    "production:preflight": "node scripts/run-production-preflight.mjs",
    "cloudflare:access:plan": "tsx scripts/cloudflare/setup-admin-access.ts --plan",
    "cloudflare:access:apply": "tsx scripts/cloudflare/setup-admin-access.ts --apply",
    "cloudflare:access:verify": "tsx scripts/cloudflare/verify-admin-access.ts",
    "db:check:payment-provider-ref": "node scripts/check-payment-provider-ref-duplicates.mjs",
    "db:ping": "node scripts/db-ping.mjs",
    "staging:validate": "npm run prisma:seed:real && npm run test:unit && npm run test:smoke:build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:preflight:provider-ref": "node scripts/check-payment-provider-ref-duplicates.mjs",
    "prisma:seed": "prisma db seed",
    "prisma:seed:real": "node prisma/seed-real-tenant.mjs"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "next": "16.2.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "dotenv": "^17.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "typescript": "^5"
  }
}
